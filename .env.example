APP_ENV=development
HTTP_ADDR=127.0.0.1:8080
DATABASE_URL=postgres://mica:mica@localhost:5432/mica
DATABASE_MAX_CONNECTIONS=10
JWT_SECRET=change-me-in-development
ACCESS_TOKEN_TTL_SECONDS=86400
RUST_LOG=mica_api_server=debug,mica_app_core=debug,mica_infra=debug,tower_http=debug

# Object storage for file uploads (S3-compatible; dev uses RustFS via
# docker-compose). Optional: when unset, the /files endpoints return 503. Set the
# four required values to enable them. The backend only SIGNS presigned URLs (no
# network calls to S3), so the host must be whatever the BROWSER can reach.
# S3_ENDPOINT=http://127.0.0.1:9000
# S3_REGION=us-east-1
# S3_BUCKET=mica
# S3_ACCESS_KEY=rustfsadmin
# S3_SECRET_KEY=rustfsadmin
# S3_FORCE_PATH_STYLE=true
# S3_PRESIGN_TTL_SECONDS=900
# S3_MAX_UPLOAD_BYTES=52428800
# Set ONLY for a public CDN / public-read bucket: download_url then returns this
# unsigned base instead of a presigned GET. Leave UNSET for a private bucket
# (RustFS/MinIO default) so downloads use signed, time-limited URLs.
# S3_PUBLIC_BASE_URL=https://cdn.example.com

# AI text generation (Anthropic Messages API). Optional: when no key is set the
# /api/ai/* endpoints return 503 and the in-app AI features are disabled.
# ANTHROPIC_API_KEY=sk-ant-...
# AI_MODEL=claude-sonnet-4-6
# AI_MAX_TOKENS=2048
# AI_BASE_URL=https://api.anthropic.com
# ANTHROPIC_VERSION=2023-06-01
