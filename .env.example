APP_ENV=development
HTTP_ADDR=127.0.0.1:8080
DATABASE_URL=postgres://mica:mica@localhost:5432/mica
DATABASE_MAX_CONNECTIONS=10
JWT_SECRET=change-me-in-development
ACCESS_TOKEN_TTL_SECONDS=86400
RUST_LOG=mica_api_server=debug,mica_app_core=debug,mica_infra=debug,tower_http=debug

# Object storage for file uploads (S3 / MinIO). Optional: when unset, the
# /files endpoints return 503. Set all four required values to enable them.
# S3_ENDPOINT=http://127.0.0.1:9000
# S3_REGION=us-east-1
# S3_BUCKET=mica
# S3_ACCESS_KEY=minioadmin
# S3_SECRET_KEY=minioadmin
# S3_FORCE_PATH_STYLE=true
# S3_PRESIGN_TTL_SECONDS=900
# S3_MAX_UPLOAD_BYTES=26214400
# S3_PUBLIC_BASE_URL=

# AI text generation (Anthropic Messages API). Optional: when no key is set the
# /api/ai/* endpoints return 503 and the in-app AI features are disabled.
# ANTHROPIC_API_KEY=sk-ant-...
# AI_MODEL=claude-sonnet-4-6
# AI_MAX_TOKENS=2048
# AI_BASE_URL=https://api.anthropic.com
# ANTHROPIC_VERSION=2023-06-01
