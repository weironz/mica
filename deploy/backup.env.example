# Mica backup config — copy to /etc/mica/backup.env, fill in, `chmod 600`.
# Loaded by mica-backup.service (systemd EnvironmentFile). Contains secrets:
# keep it root-only, and keep MICA_BACKUP_PASSWORD off this host too (see docs).

# --- mica-cli export (content side) ---
MICA_SERVER=https://mica.cloudcele.com
MICA_TOKEN=paste-a-mica-access-token-here

# --- mica-backup (restic engine) ---
# Repo path inside the bucket. Local-repo alternative: MICA_BACKUP_REPO=/var/backups/mica
MICA_BACKUP_REPO=opendal:s3:/mica
MICA_BACKUP_PASSWORD=a-strong-repo-password-stored-ALSO-off-this-host

# Backend options (Aliyun OSS). enable_virtual_host_style=true is REQUIRED for OSS.
# Use a least-privilege RAM AccessKey scoped to just this bucket.
MICA_BACKUP_OPTS=bucket=mica-backups endpoint=https://oss-cn-hangzhou.aliyuncs.com region=oss-cn-hangzhou access_key_id=LTAI... secret_access_key=... enable_virtual_host_style=true

# --- optional ---
MICA_EXPORT_DIR=/var/lib/mica/export
KEEP_DAILY=14
KEEP_WEEKLY=8
KEEP_MONTHLY=6
