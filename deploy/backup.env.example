# Mica backup config — copy to /etc/mica/backup.env, fill in, `chmod 600`.
# Loaded by mica-backup.service (systemd EnvironmentFile). Contains secrets:
# keep it root-only, and keep MICA_BACKUP_PASSWORD off this host too (see docs).

# --- mica-cli export (content side) ---
MICA_SERVER=https://mica.cloudcele.com
MICA_TOKEN=paste-a-mica-access-token-here

# --- mica-backup (restic engine) ---
# Repo path inside the bucket. Local-repo alternative: MICA_BACKUP_REPO=/var/backups/mica
MICA_BACKUP_REPO=opendal:s3:/mica
MICA_BACKUP_PASSWORD=a-strong-repo-password-stored-ALSO-off-this-host

# Backend options (Aliyun OSS), one per line as MICA_OPT_<KEY> (→ opendal <key>).
# enable_virtual_host_style=true is REQUIRED for OSS. Use a least-privilege RAM
# AccessKey scoped to just this bucket.
MICA_OPT_BUCKET=mica-backups
MICA_OPT_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com
MICA_OPT_REGION=oss-cn-hangzhou
MICA_OPT_ACCESS_KEY_ID=LTAI...
MICA_OPT_SECRET_ACCESS_KEY=...
MICA_OPT_ENABLE_VIRTUAL_HOST_STYLE=true
# Object-key prefix; set a fresh one to share a bucket with another repo.
MICA_OPT_ROOT=mica
# (Equivalent packed form, if you prefer one line:
#  MICA_BACKUP_OPTS=bucket=… endpoint=… region=… access_key_id=… secret_access_key=… enable_virtual_host_style=true root=…)

# --- optional ---
MICA_EXPORT_DIR=/var/lib/mica/export
KEEP_DAILY=14
KEEP_WEEKLY=8
KEEP_MONTHLY=6
