# Production environment — copy to the repo root as `.env.prod` and edit.
# NEVER commit the real file (gitignored).
#
# Matches the canonical stack `deploy/docker-compose.yml` (behind an existing
# Traefik). For the single-server variant `deploy/docker-compose.single.yml`,
# replace the two DOMAIN lines with `SERVER_IP=<ip-or-host>` (see the note).

# ── Rolling image tag the node loads (api + web + backup share it) ───────────
MICA_VERSION=v0.3

# ── Public hostnames — Traefik routes these; both need DNS A records ─────────
DOMAIN=mica.example.com
S3_DOMAIN=s3.mica.example.com          # presigned S3 URLs embed this; own record
# Single-server variant instead (no Traefik): SERVER_IP=<ip-or-host>

# ── App CORS (browser cross-origin reads) ────────────────────────────────────
# Empty/unset = deny all cross-origin (the web app is served same-origin with
# /api, so it needs no grant). Set ONLY if a separate origin must call the API.
# CORS_ALLOWED_ORIGINS=https://other.example.com,https://app2.example.com

# ── Accounts: public self-registration ───────────────────────────────────────
# Unset/true = open registration (POST /auth/register). Set false to lock the
# node to its existing accounts (endpoint then 403s). Login/refresh unaffected.
# MICA_REGISTRATION_ENABLED=true

# ── Password-reset email (see docs/password-reset.md) ────────────────────────
# Default backend "log" writes the reset link to the SERVER LOG and sends nothing
# — the flow still works (read the link from the logs), so leaving this unset is
# a valid "no email yet" state. Set "directmail" + the vars below to send via
# Aliyun DirectMail (邮件推送); missing required vars fall back to "log" with a
# warning, never a crash. MICA_MAIL_FROM must match the verified DirectMail
# sender address exactly. The sender domain is DNS-only (TXT/DKIM) — it needs no
# A record and no Traefik rule; only the reset-LINK domain (below) is inbound.
# MICA_APP_BASE_URL=https://mica.example.com     # origin the emailed link points at; default https://<DOMAIN>
# MICA_MAIL_BACKEND=directmail
# MICA_MAIL_FROM=noreply@mail.example.com        # verified DirectMail sender address (AccountName)
# MICA_MAIL_FROM_NAME=Mica                       # optional display name recipients see
# MICA_MAIL_ACCESS_KEY_ID=
# MICA_MAIL_ACCESS_KEY_SECRET=
# MICA_MAIL_REGION=cn-hangzhou                   # default; rarely changed
# MICA_MAIL_ENDPOINT=https://dm.aliyuncs.com/    # default; only for a regional endpoint

# ── Secrets — generate strong values:  openssl rand -hex 32 ──────────────────
JWT_SECRET=change-me
POSTGRES_PASSWORD=change-me
POSTGRES_USER=mica
POSTGRES_DB=mica

# ── RustFS (S3-compatible store for image bytes) ─────────────────────────────
S3_BUCKET=mica
S3_ACCESS_KEY=change-me
S3_SECRET_KEY=change-me
S3_REGION=us-east-1

# ── Backup (opt-in: `docker compose --profile backup up -d`; see docs/backup.md)
# A read-scoped Mica PAT + a rustic repo password + a LEAST-PRIVILEGE Aliyun OSS
# RAM AccessKey scoped to one bucket. Leave blank to run without backups.
MICA_BACKUP_TOKEN=
MICA_BACKUP_PASSWORD=                   # SAVE OFF-HOST — lose it, lose the repo
OSS_BUCKET=
OSS_ENDPOINT=https://oss-cn-shenzhen.aliyuncs.com
OSS_REGION=oss-cn-shenzhen
OSS_ACCESS_KEY_ID=
OSS_SECRET_ACCESS_KEY=
OSS_ROOT=mica
# optional: BACKUP_HOUR=3  KEEP_DAILY=7  KEEP_WEEKLY=4  KEEP_MONTHLY=6
