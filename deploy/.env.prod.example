# Production environment — copy to the repo root as `.env.prod` and edit.
# NEVER commit the real file (gitignored).

# The address users type into the browser (and that presigned S3 URLs embed).
SERVER_IP=192.168.73.6

# Generate strong values:  openssl rand -hex 32
JWT_SECRET=change-me
POSTGRES_PASSWORD=change-me

POSTGRES_USER=mica
POSTGRES_DB=mica

S3_BUCKET=mica
S3_ACCESS_KEY=change-me
S3_SECRET_KEY=change-me
S3_REGION=us-east-1
