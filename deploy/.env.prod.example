# Production environment — copy to the repo root as `.env.prod` and edit.
# NEVER commit the real file (gitignored).
#
# Matches the canonical stack `deploy/docker-compose.yml` (behind an existing
# Traefik). For the single-server variant `deploy/docker-compose.single.yml`,
# replace the two DOMAIN lines with `SERVER_IP=<ip-or-host>` (see the note).

# ── Rolling image tag the node loads (api + web + backup share it) ───────────
MICA_VERSION=v0.3

# ── Public hostnames — Traefik routes these; both need DNS A records ─────────
DOMAIN=mica.example.com
S3_DOMAIN=s3.mica.example.com          # presigned S3 URLs embed this; own record
# Single-server variant instead (no Traefik): SERVER_IP=<ip-or-host>

# ── App CORS (browser cross-origin reads) ────────────────────────────────────
# Empty/unset = deny all cross-origin (the web app is served same-origin with
# /api, so it needs no grant). Set ONLY if a separate origin must call the API.
# CORS_ALLOWED_ORIGINS=https://other.example.com,https://app2.example.com

# ── Secrets — generate strong values:  openssl rand -hex 32 ──────────────────
JWT_SECRET=change-me
POSTGRES_PASSWORD=change-me
POSTGRES_USER=mica
POSTGRES_DB=mica

# ── RustFS (S3-compatible store for image bytes) ─────────────────────────────
S3_BUCKET=mica
S3_ACCESS_KEY=change-me
S3_SECRET_KEY=change-me
S3_REGION=us-east-1

# ── Backup (opt-in: `docker compose --profile backup up -d`; see docs/backup.md)
# A read-scoped Mica PAT + a rustic repo password + a LEAST-PRIVILEGE Aliyun OSS
# RAM AccessKey scoped to one bucket. Leave blank to run without backups.
MICA_BACKUP_TOKEN=
MICA_BACKUP_PASSWORD=                   # SAVE OFF-HOST — lose it, lose the repo
OSS_BUCKET=
OSS_ENDPOINT=https://oss-cn-shenzhen.aliyuncs.com
OSS_REGION=oss-cn-shenzhen
OSS_ACCESS_KEY_ID=
OSS_SECRET_ACCESS_KEY=
OSS_ROOT=mica
# optional: BACKUP_HOUR=3  KEEP_DAILY=7  KEEP_WEEKLY=4  KEEP_MONTHLY=6
